{
  "name": "AQA Python Notebooks",
  "image": "mcr.microsoft.com/devcontainers/anaconda:latest",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-toolsai.jupyter",
        "ms-python.python"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/opt/conda/bin/python",
        "jupyter.defaultKernel": "python3"
      }
    }
  },
  "postCreateCommand": "pip install ipywidgets ipykernel && pip install -e ."
}